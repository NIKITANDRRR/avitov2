# Avito Monitor Configuration

# Поисковые запросы теперь настраиваются через config/products.json и config/categories.json
# SEARCH_URLS больше не используется для seed-данных

# Collection limits
MAX_SEARCH_PAGES_PER_RUN=50
MAX_ADS_PER_SEARCH_PER_RUN=10

# Delays (seconds)
MIN_DELAY_SECONDS=4.0
MAX_DELAY_SECONDS=10.0
STARTUP_DELAY_MIN=0.0
STARTUP_DELAY_MAX=30.0

# Browser settings
HEADLESS=false
USE_PROXY=false
PROXY_URL=

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# Telegram MTProto
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=
MTPROXY_ENABLED=true
MTPROXY_ADDRESS=135.136.188.80
MTPROXY_PORT=15871
MTPROXY_SECRET=your-mtproto-secret-here

# PostgreSQL
DATABASE_URL=postgresql://avito:avito@localhost:5432/avito_monitor

# Analysis
UNDERVALUE_THRESHOLD=0.8

# === Параметры фильтрации аномалий ===
# % отбрасывания с каждого края (5%)
TRIM_PERCENT=0.05
# Множитель для IQR fences
IQR_MULTIPLIER=1.5
# Окно анализа в днях
TEMPORAL_WINDOW_DAYS=14
# Минимальный размер сегмента для анализа
MIN_SEGMENT_SIZE=3
# Порог composite score для недооценённости
UNDERVALUED_THRESHOLD=0.3
# Порог z-score для аномалий
ZSCORE_THRESHOLD=1.5
# Порог % от медианы для недооценённости
MEDIAN_DISCOUNT_THRESHOLD=0.85

# === Параметры масштабирования поиска ===
# Макс. параллельных поисков в батче
MAX_CONCURRENT_SEARCHES=3
# Макс. параллельно открываемых карточек объявлений
MAX_CONCURRENT_AD_PAGES=5
# Интервал запуска по умолчанию (часы)
DEFAULT_SCHEDULE_INTERVAL_HOURS=0.5
# Карточек на поиск за запуск по умолчанию
DEFAULT_MAX_ADS_TO_PARSE=10
# Задержка между батчами поисков (сек)
BATCH_DELAY_SECONDS=30
# Задержка между поисками в батче (сек)
SEARCH_DELAY_SECONDS=5

# === Раздельные rate limiter'ы ===
# Максимум запросов поиска в минуту
SEARCH_RATE_LIMIT_PER_MINUTE=8
# Максимум запросов карточек в минуту
AD_RATE_LIMIT_PER_MINUTE=10

# === Настройки retry ===
# Максимум попыток при ошибке загрузки
RETRY_MAX_ATTEMPTS=3
# Базовая задержка для exponential backoff (сек)
RETRY_BACKOFF_BASE=5.0
# Максимальная задержка retry (сек)
RETRY_BACKOFF_MAX=60.0

# === Настройки изоляции контекста ===
# Создавать отдельный контекст браузера на каждый поиск
USE_ISOLATED_CONTEXTS=true

# Storage
RAW_HTML_PATH=data/raw_html

# Logging
LOG_LEVEL=INFO

# Email notifications (fallback)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=
EMAIL_TO=  # comma-separated list of recipient emails

# --- Seller Profile Parsing ---
SELLER_PROFILE_ENABLED=true
SELLER_RATE_LIMIT_PER_MINUTE=3
SELLER_MAX_PROFILES_PER_CYCLE=10
SELLER_MAX_PAGES_PER_PROFILE=3
SELLER_SCRAPE_INTERVAL_HOURS=24
SELLER_PAGE_DELAY_MIN=5.0
SELLER_PAGE_DELAY_MAX=12.0

# === Force parse mode ===
# Задержка после парсинга товаров перед категориями (сек)
FORCE_PARSE_PRODUCT_DELAY_SECONDS=60
# Интервал между категориями при force-parse (сек)
FORCE_PARSE_CATEGORY_INTERVAL_SECONDS=60
