# Avito Monitor Configuration

# Search URLs (comma-separated, up to 3)
SEARCH_URLS=https://www.avito.ru/rossiya/telefony?q=iphone+15&sgtd=5&params=201950-202094.6256258559&s=104&user=1,https://www.avito.ru/rossiya/noutbuki?q=macbook+air+m2&sgtd=5&params=201950-202094.6256258559&s=104&user=1,https://www.avito.ru/rossiya/planshety?q=ipad+pro&sgtd=5&params=201950-202094.6256258559&s=104&user=1

# Collection limits
MAX_SEARCH_PAGES_PER_RUN=3
MAX_ADS_PER_SEARCH_PER_RUN=3

# Delays (seconds)
MIN_DELAY_SECONDS=5.0
MAX_DELAY_SECONDS=15.0
STARTUP_DELAY_MIN=0.0
STARTUP_DELAY_MAX=30.0

# Browser settings
HEADLESS=false
USE_PROXY=false
PROXY_URL=

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# Telegram MTProto
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=
MTPROXY_ENABLED=true
MTPROXY_ADDRESS=135.136.188.80
MTPROXY_PORT=15871
MTPROXY_SECRET=your-mtproto-secret-here

# PostgreSQL
DATABASE_URL=postgresql://avito:avito@localhost:5432/avito_monitor

# Analysis
UNDERVALUE_THRESHOLD=0.8

# === Параметры фильтрации аномалий ===
# % отбрасывания с каждого края (5%)
TRIM_PERCENT=0.05
# Множитель для IQR fences
IQR_MULTIPLIER=1.5
# Окно анализа в днях
TEMPORAL_WINDOW_DAYS=14
# Минимальный размер сегмента для анализа
MIN_SEGMENT_SIZE=3
# Порог composite score для недооценённости
UNDERVALUED_THRESHOLD=0.3
# Порог z-score для аномалий
ZSCORE_THRESHOLD=1.5
# Порог % от медианы для недооценённости
MEDIAN_DISCOUNT_THRESHOLD=0.85

# === Параметры масштабирования поиска ===
# Макс. параллельных поисков в батче
MAX_CONCURRENT_SEARCHES=3
# Интервал запуска по умолчанию (часы)
DEFAULT_SCHEDULE_INTERVAL_HOURS=2
# Карточек на поиск за запуск по умолчанию
DEFAULT_MAX_ADS_TO_PARSE=3
# Задержка между батчами поисков (сек)
BATCH_DELAY_SECONDS=30
# Задержка между поисками в батче (сек)
SEARCH_DELAY_SECONDS=5

# Storage
RAW_HTML_PATH=data/raw_html

# Logging
LOG_LEVEL=INFO

# Email notifications (fallback)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=
EMAIL_TO=  # comma-separated list of recipient emails
